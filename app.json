{
  "expo": {
    "name": "JalSathi",
    "slug": "jalsathi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-xlp.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-xlp.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.placeholder.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "JalSathi uses your location to show nearby hazards and auto-tag your reports."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-xlp.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.placeholder.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/newly.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "scheme": "jalsathi",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://yenatqntu9swue9p2wf8rkecdaqrvkk2.app.specular.dev"
    }
  }
}